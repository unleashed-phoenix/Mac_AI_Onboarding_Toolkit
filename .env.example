# Copy to .env in the sub-folder you are working in, then fill in.
# .env is gitignored. NEVER commit real keys.

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google (Gemini / ADK)
GOOGLE_API_KEY=

# OpenRouter (one key, many models)
OPENROUTER_API_KEY=

# Hugging Face
HF_TOKEN=

# xAI (Grok)  -- xAI, Elon Musk. NOT "Groq".
XAI_API_KEY=

# LangSmith tracing (optional)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true

# Ollama local endpoint (no key needed)
OLLAMA_HOST=http://localhost:11434
